# Public (exposed to the browser only when prefixed with NEXT_PUBLIC_)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# OpenRouter — used only by scripts/generate-site-images.mjs (locally). In CI, use the
# repository secret OPENROUTER_API_KEY (see .github/workflows/generate-site-images.yml).
# OPENROUTER_API_KEY=sk-or-v1-...
# Optional override (default is best-quality): OPENROUTER_IMAGE_MODEL=openai/gpt-5-image

# Optional: Google Business Profile URLs for reviews CTAs (match your live GBP)
# NEXT_PUBLIC_GOOGLE_BUSINESS_PROFILE_URL=https://g.page/r/your-profile
# NEXT_PUBLIC_GOOGLE_REVIEWS_URL=https://search.google.com/local/writereview?placeid=ChIJ...

# Server-only: optional webhook URL for contact form JSON POST (name, email, phone, message, propertyInterest, preferredContact, site, submittedAt)
# CONTACT_WEBHOOK_URL=https://example.com/api/contact-hook
